// Firestore Security Rules for GTO Duel
//
// Paste the contents of this file into your Firebase project's Firestore
// Rules tab (Firebase Console > Firestore Database > Rules) and click
// Publish. Only the two players in a game may read or write its document,
// and a third player cannot join.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{gameId} {

      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participantUids;

      allow create: if request.auth != null
                    && request.resource.data.participantUids.size() == 1
                    && request.resource.data.participantUids[0] == request.auth.uid
                    && request.resource.data.status == 'waiting_for_opponent';

      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.participantUids
                        || (resource.data.participantUids.size() == 1
                            && request.resource.data.participantUids.size() == 2
                            && request.auth.uid in request.resource.data.participantUids));

      allow delete: if false;
    }
  }
}
